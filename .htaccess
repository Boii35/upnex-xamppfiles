# ============================================================
#  UPNEX — Apache .htaccess
#  Dành cho XAMPP localhost
# ============================================================

Options -Indexes

# ── Bảo mật: Chặn truy cập trực tiếp vào thư mục nhạy cảm ──
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Chặn truy cập trực tiếp vào /model, /controller, /config
  RewriteRule ^(model|controller|config)(/|$) - [F,L]
</IfModule>

# ── Security Headers ─────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Chặn truy cập file nhạy cảm ─────────────────────────────
<FilesMatch "\.(sql|log|env|git|md)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# ── PHP error log ────────────────────────────────────────────
php_flag display_errors On
php_value error_reporting 32767
